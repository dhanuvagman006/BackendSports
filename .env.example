# ---- Server ----
NODE_ENV=development
PORT=8080
CORS_ORIGINS=*

# ---- PostgreSQL ----
DATABASE_URL=postgres://sportyqo:sportyqo@localhost:5432/sportyqo

# ---- JWT ----
JWT_ACCESS_SECRET=change-me-64-random-chars
JWT_REFRESH_SECRET=change-me-different-64-random-chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_DAYS=30

# ---- Object storage (MinIO in dev, S3/R2/Spaces in prod) ----
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=sportyqo
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_FORCE_PATH_STYLE=true
# Set to your CDN/public bucket base URL to serve files directly (else presigned URLs are used)
S3_PUBLIC_BASE_URL=
